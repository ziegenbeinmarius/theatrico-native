# Theatrico Native — Environment Variables
#
# Copy this file to .env and fill in your values.
# These are injected into app.config.ts via process.env and surfaced to
# the app through expo-constants (Constants.expoConfig.extra).
#
# The app also lets operators override BACKEND_URL at runtime from the
# Settings screen (persisted to AsyncStorage), so this env var is only
# the initial default used at build time.

# Base URL of the Theatrico backend.
# Supports http://, https://, ws://, or wss:// — the app converts http→ws
# automatically for WebSocket connections.
# Default (when blank): http://localhost:8080
BACKEND_URL=http://localhost:8080
